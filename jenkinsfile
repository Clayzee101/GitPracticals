pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/Clayzee101/GitPracticals.git'
            }
        }

        stage('Publish HTML') {
            steps {
                publishHTML(target: [
                    allowMissing: true,
                    alwaysLinkToLastBuild: false,
                    keepAll: true,
                    reportDir: '.',
                    reportFiles: 'doc.html',
                    reportName: 'My HTML Page'
                ])
            }
        }
    }
}
